<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- All logs: JSON format for ELK -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <!-- API call logs: rolling file for ELK Filebeat/Logstash to pick up -->
    <appender name="API_LOG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/api-calls.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/api-calls.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Dedicated logger for structured API call records -->
    <logger name="API_CALL_LOG" level="INFO" additivity="false">
        <appender-ref ref="API_LOG_FILE"/>
        <appender-ref ref="JSON_CONSOLE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

</configuration>
